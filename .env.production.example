# Copia a .env.production y rellena con valores reales.
# NUNCA subas .env.production a Git.

# Genera con (desde el repo, con PHP instalado):
#   php artisan key:generate --show
APP_KEY=

# Genera con: openssl rand -base64 32
DB_PASSWORD=

# Genera con: openssl rand -base64 32  (distinto de DB_PASSWORD)
DB_ROOT_PASSWORD=

# URL pública de SolStay (sin barra final)
APP_URL=http://solstay.duckdns.org

# true solo la primera vez (carga propiedades demo y usuarios admin/guest)
RUN_SEEDER=true

# Referencia para la guía (no lo usa Docker directamente)
SOLSTAY_DOMAIN=solstay.duckdns.org
DOJO_DOMAIN=spring-dojo.duckdns.org
